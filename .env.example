# AI — Ollama via OpenAI-compatible endpoint (local testing)
AI_PROVIDER=openai
AI_MODEL=gemma4:12b
OPENAI_BASE_URL=http://localhost:11434/v1
# Ollama ignores the key but LangChain/OpenAI client requires one
OPENAI_API_KEY=ollama

# --- Or use Google Gemini instead ---
# AI_PROVIDER=google-genai
# AI_MODEL=gemini-2.0-flash
# GOOGLE_API_KEY=your_google_api_key_here

# Instagram (Instagram API with Instagram Login)
IG_ACCESS_TOKEN=
IG_USER_ID=
IG_API_VERSION=v25.0

# Must be a public HTTPS URL Instagram can fetch — use ngrok/cloudflare tunnel for local dev
PUBLIC_BASE_URL=https://your-tunnel.example.com

PORT=3000
